import pathway as pw

class AirQuality(pw.Schema):
    city: str
    pm25: float
    temperature: float

# Real streaming CSV input
input_table = pw.io.csv.read(
    "air_data.csv",
    schema=AirQuality,
    mode="streaming",
)

# Risk calculation
risk_table = input_table.select(
    city=pw.this.city,
    pm25=pw.this.pm25,
    temperature=pw.this.temperature,
    risk_score=pw.this.pm25 * 0.7 + pw.this.temperature * 0.3,
)

# Write output continuously
pw.io.csv.write(
    risk_table,
    "output.csv",
)

pw.run()
import pathway as pw
import random

class AirQuality(pw.Schema):
    city: str
    pm25: float
    temperature: float

cities = ["Delhi", "Mumbai", "Bangalore"]

input_table = pw.demo.generate_custom_stream(
    {
        "city": lambda: random.choice(cities),
        "pm25": lambda: random.uniform(50, 300),
        "temperature": lambda: random.uniform(20, 40),
    },
    schema=AirQuality,
)

risk_table = input_table.select(
    city=pw.this.city,
    pm25=pw.this.pm25,
    temperature=pw.this.temperature,
    risk_score=pw.this.pm25 * 0.7 + pw.this.temperature * 0.3,
)

pw.io.csv.write(
    risk_table,
    "output.csv",
)

pw.run()
