import streamlit as st
import pandas as pd

st.set_page_config(page_title="GreenGuard", layout="wide")

st.title("🌍 GreenGuard - Live AQI Dashboard")

# Load data
df = pd.read_csv("air_data.csv")

# Show latest value per city
st.subheader("🔴 Latest AQI Status")

latest = df.groupby("city").tail(1)

cols = st.columns(len(latest))

for col, (_, row) in zip(cols, latest.iterrows()):
    col.metric(
        label=row["city"],
        value=f"PM2.5: {row['pm25']}",
        delta=f"Temp: {row['temperature']}°C"
    )

# Trend section
st.subheader("📈 AQI Trend")

selected_city = st.selectbox("Select City", df["city"].unique())

city_df = df[df["city"] == selected_city]

st.line_chart(city_df["pm25"])

# Raw data
st.subheader("📊 Raw Data")
st.dataframe(df)
